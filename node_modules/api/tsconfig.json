{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "rootDir": ".", 
    "outDir": "dist",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      // SỬA DÒNG NÀY: Trỏ vào dist thay vì src
      "@smart-terrarium/shared-types": ["../../packages/shared-types/dist/index"]
    }
  },
  "include": ["api/**/*", "lib/**/*"]
}