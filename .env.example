# ==========================================
# Copy this file to each service directory:
# - services/api/.env
# - services/mqtt-worker/.env
# - services/ai-agent/.env
# ==========================================

# --- Database (MongoDB) ---
MONGODB_URI="mongodb+srv://<replace_user>:<replace_pass>@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="hermit-home"
MONGODB_MAX_POOL_SIZE=10

# --- MQTT Broker (HiveMQ) ---
MQTT_BROKER="<replace_cluster_id>.hivemq.cloud"
MQTT_PORT=8883
MQTT_USER="<replace_mqtt_user>"
MQTT_PASS="<replace_mqtt_pass>"
# Optional custom root CA certificate in PEM format, newline escaped.
MQTT_CA_CERT=""

# --- API Auth ---
# Shared secret used by service-to-service calls (AI agent -> API).
SERVICE_API_KEY="<replace_with_long_random_secret>"
# JWT signing secret for /api/users/login and internal Bearer-token verification.
JWT_SECRET="<replace_with_long_random_secret>"
# Required only for Firebase Bearer-token verification path.
FIREBASE_SERVICE_ACCOUNT_KEY=""

# --- Password reset email ---
# Frontend/app URL that receives the reset token as a query param.
# Examples:
# - hermithome://reset-password
# - https://your-app.example.com/reset-password
PASSWORD_RESET_URL=""
# Optional deep link target used by GET /reset-password HTML bridge.
# Must match app deep link settings.
PASSWORD_RESET_DEEPLINK_SCHEME="hermithome"
PASSWORD_RESET_DEEPLINK_HOST="reset-password"
# Token expiry window for reset links.
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# SMTP config used to send reset email.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
# Example: Hermit Home <no-reply@your-domain.com>
SMTP_FROM=""

# --- Worker Authorization ---
# Comma-separated list of authorized MongoDB ObjectId values.
ALLOWED_DEVICE_IDS="<replace_with_device_id_or_ids>"

# --- AI Agent Variables ---
API_BASE_URL="http://localhost:3000"
DEVICE_ID="<replace_with_test_device_id>"
HTTP_TIMEOUT_SECONDS=10

# --- mqtt-worker self keepalive (Render web service) ---
# If SELF_PING_URL is empty, worker falls back to ${RENDER_EXTERNAL_URL}/ping
SELF_PING_URL=""
SELF_PING_INTERVAL_MS=180000
SELF_PING_TIMEOUT_MS=10000
