{
  "version": 2,
  "builds": [
    {
      "src": "services/api/api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/render-keepalive",
      "schedule": "*/3 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/cron/render-keepalive",
      "dest": "/services/api/api/cron/render-keepalive.ts"
    },
    {
      "src": "/api/users/login",
      "dest": "/services/api/api/users/login.ts"
    },
    {
      "src": "/api/users/register",
      "dest": "/services/api/api/users/register.ts"
    },
    {
      "src": "/api/devices/([^/]+)/status",
      "dest": "/services/api/api/devices/[deviceId]/status.ts"
    },
    {
      "src": "/api/devices/([^/]+)/override",
      "dest": "/services/api/api/devices/[deviceId]/override.ts"
    },
    {
      "src": "/api/devices/([^/]+)/control",
      "dest": "/services/api/api/devices/[deviceId]/control.ts"
    },
    {
      "src": "/api/devices/schedules",
      "dest": "/services/api/api/devices/schedules/index.ts"
    },
    {
      "src": "/api/devices/([^/]+)",
      "dest": "/services/api/api/devices/[deviceId]/index.ts"
    },
    {
      "src": "/api/devices",
      "dest": "/services/api/api/devices/index.ts"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/services/api/api/auth/[...nextauth].ts"
    }
  ]
}
